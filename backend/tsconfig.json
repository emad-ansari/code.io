{
	"compilerOptions": {

		"target": "ES2020",
		"types": ["node"],
		"lib": ["ES2020", "DOM"],
		"module": "commonjs",
		"rootDir": "./",
		"outDir": "./dist",
		"esModuleInterop": true,

		"forceConsistentCasingInFileNames": true,

		"strict": true,

		"skipLibCheck": true,
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules"]
}
